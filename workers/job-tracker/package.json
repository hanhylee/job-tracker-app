{
  "name": "cloudflare-workers-openapi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy": "wrangler versions upload",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "auth:generate": "auth generate --config ./better-auth.config.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate:remote": "wrangler d1 migrations apply db --remote"
  },
  "dependencies": {
    "better-auth": "^1.6.10",
    "chanfana": "^3.3.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "wrangler": "^4.90.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
